# 小米 MiMo API 配置（推荐，与 Claude Code 共用同一套 Key）
ANTHROPIC_API_KEY=tp-你的-MiMo-API-Key
ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
ANTHROPIC_DEFAULT_MODEL=mimo-v2.5-pro
# 对话页模型列表见 GET /api/models；Token Plan 套餐目前仅支持 mimo-v2.5-pro

# 或使用 Anthropic 官方 API（二选一）
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# DeepSeek（CC-Switch / Claude Code，见 scripts/setup_cc_switch_deepseek.py）
# DEEPSEEK_API_KEY=sk-你的-DeepSeek-Key

# 剑鱼标讯（标书信息获取 SKILL）
JIANYU_PHONE=你的手机号
JIANYU_PASSWORD=你的密码

# 年报分析：PDF 分页提取与按章节阅读（0 表示不截断全文）
ANNUAL_REPORT_MAX_PDF_PAGES=250
ANNUAL_REPORT_SECTION_MAX_CHARS=45000
# ANNUAL_REPORT_MAX_TEXT_CHARS=0

# 每日智能体开发报告（8:00 邮件，Gmail）
REPORT_TO_EMAIL=linyibai20201101@gmail.com
SMTP_USER=linyibai20201101@gmail.com
SMTP_PASSWORD=Gmail应用专用密码
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# REPORT_EMAIL_SUBJECT=[ccbaby] 智能体开发日报
